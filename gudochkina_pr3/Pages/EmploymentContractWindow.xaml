<Window x:Class="gudochkina_pr3.Pages.EmploymentContractWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:gudochkina_pr3.Pages"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Создание трудового договора" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Данные сотрудника из БД -->
        <Border Grid.Row="0" Background="#F0F0F0" Padding="10" Margin="0,0,0,10" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Данные сотрудника" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <TextBlock Text="ФИО:" FontWeight="Bold"/>
                <TextBlock x:Name="EmployeeNameTextBlock" Margin="0,0,0,5"/>
                <TextBlock Text="Должность:" FontWeight="Bold"/>
                <TextBlock x:Name="EmployeePositionTextBlock" Margin="0,0,0,5"/>
            </StackPanel>
        </Border>

        <!-- Поля для ввода данных договора -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,5">
                <TextBlock Text="Номер договора:" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox x:Name="ContractNumberTextBox" Margin="0,2,0,5" Padding="5"/>

                <TextBlock Text="Город:" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox x:Name="CityTextBox" Margin="0,2,0,5" Padding="5" Text="Москва"/>

                <TextBlock Text="Дата заключения:" FontWeight="Bold" Margin="0,5,0,0"/>
                <StackPanel Orientation="Horizontal" Margin="0,2,0,5">
                    <TextBox x:Name="ContractDayTextBox" Width="50" Padding="5" Text="1"/>
                    <TextBox x:Name="ContractMonthTextBox" Width="80" Padding="5"  Text="Января"/>
                    <TextBox x:Name="ContractYearTextBox" Width="70" Padding="5" Text="2026"/>
                </StackPanel>

                <TextBlock Text="Работодатель (название):" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox x:Name="EmployerNameTextBox" Margin="0,2,0,5" Padding="5" Text="ООО &quot;Фотоцентр&quot;"/>

                <TextBlock Text="Генеральный директор (ФИО):" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox x:Name="DirectorNameTextBox" Margin="0,2,0,5" Padding="5" Text="Иванов Иван Иванович"/>

                <TextBlock Text="Адрес работодателя:" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox x:Name="EmployerAddressTextBox" Margin="0,2,0,5" Padding="5" Text="г. Москва, ул. Примерная, д. 1"/>

                <TextBlock Text="ИНН/КПП работодателя:" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox x:Name="EmployerInnKppTextBox" Margin="0,2,0,5" Padding="5" Text="7700000000/770001001"/>

                <TextBlock Text="Испытательный срок (мес.):" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox x:Name="TestPeriodTextBox" Margin="0,2,0,5" Padding="5" Text="3"/>

                <TextBlock Text="Зарплата (руб.):" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox x:Name="EmployeeSalaryTextBox" Margin="0,2,0,5" Padding="5" Text="50000"/>

                <TextBlock Text="Паспортные данные сотрудника" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBlock Text="Серия и номер паспорта:" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox x:Name="PassportSeriesTextBox" Margin="0,2,0,5" Padding="5"/>
                <TextBlock Text="Кем выдан:" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox x:Name="PassportIssuedByTextBox" Margin="0,2,0,5" Padding="5"/>
                <TextBlock Text="Дата выдачи:" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBox x:Name="PassportIssueDateTextBox" Margin="0,2,0,5" Padding="5"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="2" Margin="0,15,0,0">
            <Button Content="Создать договор" Click="CreateContractButton_Click" 
                    Padding="15,8" Margin="0,0,10,0" Background="LightGreen" MinWidth="120"/>
            <Button Content="Отмена" Click="CancelButton_Click" Padding="15,8" MinWidth="80"/>
        </StackPanel>
    </Grid>
</Window>
