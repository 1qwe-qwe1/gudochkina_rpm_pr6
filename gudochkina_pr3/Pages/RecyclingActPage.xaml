<Page x:Class="gudochkina_pr3.Pages.RecyclingActPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:gudochkina_pr3.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RecyclingActPage" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с кнопкой печати -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Акт приема-передачи отходов" 
                       FontSize="20" FontWeight="Bold" 
                       Margin="10" HorizontalAlignment="Center"/>
            <Button Grid.Column="1" Content="Печать акта" Margin="10" 
                    Click="PrintActButton_Click" Padding="10,5"/>
        </Grid>

        <!-- Контейнер для печати -->
        <FlowDocumentReader x:Name="flowDocumentReader" Grid.Row="1" 
                            ViewingMode="Scroll" Margin="10">
            <FlowDocument x:Name="flowDocument">
                <BlockUIContainer>
                    <StackPanel x:Name="printContent">
                        
                    </StackPanel>
                </BlockUIContainer>
            </FlowDocument>
        </FlowDocumentReader>

        <!-- Статусная строка -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="tbStatus" Text="Готово"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Page>
